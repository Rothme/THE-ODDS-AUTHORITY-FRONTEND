<script>
// ── CONFIG ────────────────────────────────────────────────────
var API_BASE = 'https://the-odds-authority-backend.onrender.com';
var SEASON = 2024;

// ── STARTUP ───────────────────────────────────────────────────
(async function healthCheck() {
  var chip = document.getElementById('statusChip');
  var lbl  = document.getElementById('statusLabel');
  try {
    var r = await fetch(API_BASE + '/health');
    var d = await r.json();
    if (d.apiKeySet) {
      chip.classList.add('connected');
      lbl.textContent = 'Live · API Connected';
    } else {
      chip.classList.add('error');
      lbl.textContent = 'API Key Missing';
      showErr('Backend connected but API key not set. Add API_FOOTBALL_KEY to your server .env file.');
    }
  } catch(e) {
    chip.classList.add('error');
    lbl.textContent = 'Backend Offline';
    showErr('Cannot reach backend server. Set API_BASE in index.html to your Render URL and ensure it is running.');
  }
})();

// ── SEARCH ────────────────────────────────────────────────────
var input    = document.getElementById('tsearch');
var dropdown = document.getElementById('dropdown');
var sugItems = [], activeIdx = -1, debTimer = null;

input.addEventListener('input', function() {
  var v = this.value.trim();
  clearTimeout(debTimer);
  hideDrop(); hideErr();
  if (v.length < 3) { spinOff(); return; }
  spinOn();
  debTimer = setTimeout(function() { doSearch(v); }, 380);
});
input.addEventListener('keydown', function(e) {
  if (dropdown.style.display !== 'block') return;
  if (e.key === 'ArrowDown') { activeIdx = Math.min(activeIdx+1, sugItems.length-1); hlDrop(); e.preventDefault(); }
  else if (e.key === 'ArrowUp') { activeIdx = Math.max(activeIdx-1, 0); hlDrop(); e.preventDefault(); }
  else if (e.key === 'Enter' && activeIdx >= 0) { pick(sugItems[activeIdx]); e.preventDefault(); }
  else if (e.key === 'Escape') hideDrop();
});
document.addEventListener('click', function(e) {
  if (!input.contains(e.target) && !dropdown.contains(e.target)) hideDrop();
});

function spinOn()  { document.getElementById('sico').style.display='none'; document.getElementById('sspin').style.display='block'; }
function spinOff() { document.getElementById('sico').style.display='block'; document.getElementById('sspin').style.display='none'; }
function hideDrop() { dropdown.style.display='none'; dropdown.innerHTML=''; activeIdx=-1; }
function hlDrop()   { dropdown.querySelectorAll('.dd-item').forEach(function(el,i){ el.classList.toggle('active', i===activeIdx); }); }

async function doSearch(q) {
  try {
    var d = await bg('/api/teams?search=' + encodeURIComponent(q));
    spinOff();
    if (d.error) { showErr(d.message); return; }
    sugItems = (d.response||[]).slice(0,8);
    activeIdx = -1;
    if (!sugItems.length) {
      dropdown.innerHTML = '<div class="dd-empty">No teams found. Try a different spelling.</div>';
      dropdown.style.display = 'block'; return;
    }
    dropdown.innerHTML = sugItems.map(function(it, i) {
      var t=it.team, v=it.venue||{};
      var logo = t.logo
        ? '<img class="dd-logo" src="'+t.logo+'" onerror="this.style.display=\'none\'">'
        : '<div class="dd-ph">⚽</div>';
      return '<div class="dd-item" onclick="pickIdx('+i+')">'
        + logo
        + '<div><div class="dd-name">'+esc(t.name)+'</div>'
        + '<div class="dd-meta">'+(v.city||'')+(v.city&&t.country?' · ':'')+esc(t.country||'')+(t.founded?' · Est. '+t.founded:'')+'</div></div>'
        + '<span class="dd-country">'+esc(t.country||'')+'</span>'
        + '</div>';
    }).join('');
    dropdown.style.display = 'block';
  } catch(e) { spinOff(); showErr('Search error: ' + e.message); }
}
function pickIdx(i) { pick(sugItems[i]); }
function pick(item) { input.value = item.team.name; hideDrop(); loadTeam(item.team); }

// ── API ───────────────────────────────────────────────────────
async function bg(path) {
  var r = await fetch(API_BASE + path);
  if (!r.ok) { var b={}; try{b=await r.json();}catch(x){} throw new Error(b.message||'Server error '+r.status); }
  return r.json();
}

// ── LOAD STEPS ────────────────────────────────────────────────
var STEPS = ['Finding upcoming fixtures…','Loading season statistics…','Fetching AI predictions…','Head-to-head history…','Checking injury reports…','Building prediction report…'];
var lstTimer=null, lstIdx=0;
function startLoad() {
  document.getElementById('lsteps').innerHTML = '';
  lstIdx = 0;
  STEPS.forEach(function(s,i){
    var d=document.createElement('div'); d.className='lstep'; d.id='ls'+i;
    d.innerHTML='<span class="lstep-ico">○</span><span>'+s+'</span>';
    document.getElementById('lsteps').appendChild(d);
  });
  lstTimer = setInterval(function(){
    if (lstIdx < STEPS.length) {
      var r=document.getElementById('ls'+lstIdx);
      if(r){r.classList.add('done');r.querySelector('.lstep-ico').textContent='✓';}
      lstIdx++;
    } else clearInterval(lstTimer);
  }, 560);
}
function stopLoad() { clearInterval(lstTimer); }

// ── LOAD TEAM ─────────────────────────────────────────────────
async function loadTeam(team) {
  hideErr();
  document.getElementById('report').style.display = 'none';
  document.getElementById('report').innerHTML = '';
  document.getElementById('loader').style.display = 'block';
  startLoad();

  try {
    var fxData = await bg('/api/fixtures?team='+team.id+'&next=5');
    var fixtures = fxData.response||[];
    if (!fixtures.length) { var p=await bg('/api/fixtures/last?team='+team.id+'&last=3'); fixtures=p.response||[]; }

    var leagueId=null, leagueName='', leagueCountry='', leagueLogo='';
    if (fixtures.length) {
      leagueId=fixtures[0].league.id; leagueName=fixtures[0].league.name;
      leagueCountry=fixtures[0].league.country; leagueLogo=fixtures[0].league.logo;
      SEASON=fixtures[0].league.season||SEASON;
    } else {
      var lgD=await bg('/api/leagues?team='+team.id+'&current=true');
      var legs=lgD.response||[];
      if(legs.length){leagueId=legs[0].league.id;leagueName=legs[0].league.name;leagueCountry=legs[0].country?.name||'';SEASON=legs[0].seasons?.[0]?.year||SEASON;}
    }

    var stats=null;
    if(leagueId){try{var sd=await bg('/api/stats?team='+team.id+'&league='+leagueId+'&season='+SEASON);stats=sd.response||null;}catch(e){}}

    var preds={};
    for(var i=0;i<Math.min(fixtures.length,3);i++){
      try{var pd=await bg('/api/predictions?fixture='+fixtures[i].fixture.id);if(pd.response&&pd.response[0])preds[fixtures[i].fixture.id]=pd.response[0];}catch(e){}
    }

    var h2h=[];
    if(fixtures.length){try{var hd=await bg('/api/h2h?h2h='+fixtures[0].teams.home.id+'-'+fixtures[0].teams.away.id+'&last=10');h2h=hd.response||[];}catch(e){}}

    var injuries=[];
    if(fixtures.length){try{var inj=await bg('/api/injuries?fixture='+fixtures[0].fixture.id);injuries=inj.response||[];}catch(e){}}

    var standings=[];
    if(leagueId){try{var st=await bg('/api/standings?league='+leagueId+'&season='+SEASON);standings=st.response?.[0]?.league?.standings?.[0]||[];}catch(e){}}

    stopLoad();
    document.getElementById('loader').style.display='none';
    renderReport(team,fixtures,stats,preds,h2h,injuries,standings,leagueName,leagueCountry);
    document.getElementById('report').style.display='block';
  } catch(e) {
    stopLoad();
    document.getElementById('loader').style.display='none';
    showErr(e.message);
  }
}

// ── PREDICTION ENGINE ─────────────────────────────────────────
function pois(lam,k){var l=Math.max(lam,.001),lp=k*Math.log(l)-l,lf=0;for(var i=1;i<=k;i++)lf+=Math.log(i);return Math.exp(lp-lf);}
function p2(lam){return Math.max(0,Math.min(1,1-pois(lam,0)-pois(lam,1)));}

function model(stats, fixture, team) {
  var m={gs:1.3,gc:1.3,cs:.2,fts:.2,wins:0,draws:0,loss:0,pl:1,sot:4,form:''};
  if(stats){
    var gf=stats.goals?.for?.average, ga=stats.goals?.against?.average;
    m.gs=parseFloat(gf?.total||gf?.home||1.3); m.gc=parseFloat(ga?.total||ga?.home||1.3);
    m.cs=(stats.clean_sheet?.total||0)/Math.max(stats.fixtures?.played?.total||1,1);
    m.fts=(stats.failed_to_score?.total||0)/Math.max(stats.fixtures?.played?.total||1,1);
    m.wins=stats.fixtures?.wins?.total||0; m.draws=stats.fixtures?.draws?.total||0;
    m.loss=stats.fixtures?.loses?.total||0; m.pl=stats.fixtures?.played?.total||1;
    m.sot=(stats.shots?.on?.total||0)/Math.max(m.pl,1); m.form=(stats.form||'').slice(-8);
  }
  var isH=fixture?fixture.teams.home.id===team.id:true, hf=isH?1.12:.88;
  var xg=Math.max(m.gs,m.sot>0?m.sot*.12:m.gs)*hf, hist=m.gs*hf;
  var lgF=Math.min(1.3,Math.max(.7,(m.gs+m.gc)/2.65));
  var fc=m.form.replace(/[^WDL]/g,'').split('').slice(-6),fw=0,fd=0,fl=0;
  fc.forEach(function(c){if(c==='W')fw++;else if(c==='D')fd++;else fl++;});
  var fs=(fw+fd+fl)>0?(fw*3+fd)/((fw+fd+fl)*3):.5;
  var lam=(xg*.35+hist*.35+(m.sot*.1*hf)*.15+xg*lgF*.15)*(.85+fs*.3);
  var pois2=p2(lam);
  var btts=Math.min(.85,Math.max(.15,m.gs*.3+(1-m.cs)*.5+.2));
  var o25=Math.min(.9,Math.max(.1,(m.gs+m.gc)/(2.65*1.6)));
  var prob=(pois2*.35+o25*.25+btts*.15+pois2*.15+fs*.10)-m.cs*.1+Math.min(.08,(m.gc-1.2)*.04);
  prob=Math.max(.05,Math.min(.96,prob));
  return {prob,lam:lam.toFixed(2),xg:xg.toFixed(2),btts,o25,fs,fc,m,isH};
}

// ── RENDER ────────────────────────────────────────────────────
function renderReport(team,fixtures,stats,preds,h2h,injuries,standings,leagueName,leagueCountry) {
  var logo=team.logo?'<img class="t-logo" src="'+team.logo+'" onerror="this.outerHTML=\'<div class=t-ph>⚽</div>\'">'
                    :'<div class="t-ph">⚽</div>';
  var html='<div class="team-strip">'+logo
    +'<div style="flex:1;min-width:0">'
    +'<div class="t-name">'+esc(team.name)+'</div>'
    +'<div class="t-meta">'+esc(team.country||'')+(team.founded?' · Est. '+team.founded:'')+'</div>'
    +(leagueName?'<div class="t-league">⚽ '+esc(leagueName)+' · '+esc(leagueCountry)+' · Season '+SEASON+'</div>':'')
    +'</div>'
    +'<button class="back-btn" onclick="clearReport()">← New Search</button>'
    +'</div>';

  // Season stats
  if (stats) {
    var pl=stats.fixtures?.played?.total||0, w=stats.fixtures?.wins?.total||0,
        d=stats.fixtures?.draws?.total||0,  l=stats.fixtures?.loses?.total||0,
        gf=stats.goals?.for?.total?.total||0, ga=stats.goals?.against?.total?.total||0,
        cs=stats.clean_sheet?.total||0,       fts=stats.failed_to_score?.total||0;
    html += sh('Season Statistics')
      +'<div class="stats-grid">'
      +sv('Played',pl,'var(--ink)') +sv('Won',w,'var(--green)') +sv('Drawn',d,'#92650a')
      +sv('Lost',l,'var(--red)')    +sv('Goals For',gf,'var(--blue)') +sv('Goals Ag.',ga,'var(--red)')
      +sv('Clean Sheets',cs,'var(--teal)') +sv('Scoreless',fts,'var(--red)')
      +'</div>';
  }

  // H2H
  if (h2h.length && fixtures.length) html += renderH2H(fixtures[0], h2h);

  // Injuries
  if (injuries.length) html += renderInjuries(injuries, fixtures[0], team);

  // Standings
  if (standings.length) html += renderStandings(standings, team);

  // Fixture cards
  html += sh(fixtures.length ? 'Upcoming Fixtures — Full Prediction Report' : 'Season Analysis');
  html += fixtures.length
    ? fixtures.map(function(fx,i){ return renderFx(fx,stats,preds[fx.fixture.id]||null,team,i); }).join('')
    : renderGeneral(stats, team);

  document.getElementById('report').innerHTML = html;
}

function renderFx(fx, stats, pred, team, idx) {
  var own = model(stats, fx, team);
  var isH = fx.teams.home.id === team.id;
  var pct = (own.prob*100).toFixed(1);

  var apiP  = pred ? pred.predictions : null;
  var apiC  = pred ? pred.comparison  : null;
  var pct_  = apiP ? apiP.percent     : null;
  var hW    = pct_ ? parseFloat(pct_.home) : (isH?45:30);
  var drw   = pct_ ? parseFloat(pct_.draw) : 25;
  var aW    = pct_ ? parseFloat(pct_.away) : (isH?30:45);
  var winner   = apiP ? apiP.winner    : null;
  var advice   = apiP ? (apiP.advice||'') : '';
  var uOver    = apiP ? (apiP.under_over||'') : '';
  var predGoals= apiP ? apiP.goals     : null;

  var dt=new Date(fx.fixture.date);
  var dstr=dt.toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short',year:'numeric'});
  var tstr=dt.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});

  function tblk(t, subj, cls) {
    var lg=t.logo?'<img class="m-tlogo" src="'+t.logo+'" onerror="this.outerHTML=\'<div class=m-tph>⚽</div>\'">'
                  :'<div class="m-tph">⚽</div>';
    return '<div class="m-side '+cls+'">'+lg+'<div class="m-tname'+(subj?' subject':'')+'">'+esc(t.name)+'</div></div>';
  }

  // Derived
  var o15=Math.min(97,(own.o25*100+15)).toFixed(0);
  var o25v=(own.o25*100).toFixed(0);
  var o35=Math.max(5,(own.o25*100-18)).toFixed(0);
  var bttsV=(own.btts*100).toFixed(0);
  var csV=(own.m.cs*100).toFixed(0);
  var dc1=Math.min(97,hW+drw).toFixed(0);
  var dc2=Math.min(97,aW+drw).toFixed(0);
  var confCls=pred?'conf-hi':'conf-md', confLbl=pred?'HIGH':'MED';

  // Tags
  var tags=[];
  if(own.prob>=.65)            tags.push({l:'Strong 2+ Signal',c:'hot'});
  if(hW>55)                    tags.push({l:'Home Favourite',c:'hot'});
  if(aW>55)                    tags.push({l:'Away Favourite',c:'hot'});
  if(Math.abs(hW-aW)<10)      tags.push({l:'Evenly Matched',c:'warm'});
  if(drw>28)                   tags.push({l:'Draw Risk',c:'warm'});
  if(own.btts>=.58)            tags.push({l:'BTTS Likely',c:'hot'});
  if(own.o25>=.62)             tags.push({l:'High-Scoring Game',c:'hot'});
  if(uOver.toLowerCase().includes('under')) tags.push({l:'Under Signal',c:'cold'});
  if(own.m.cs>=.35)            tags.push({l:'Clean Sheet Risk',c:'cold'});
  if(isH)                      tags.push({l:'Home Advantage',c:'info'});
  else                         tags.push({l:'Away Side',c:'info'});
  if(winner&&winner.name===team.name) tags.push({l:'Predicted Winner',c:'hot'});

  var narrative = '';
  if(advice)     narrative += 'Model advises: <strong>'+esc(advice)+'</strong>. ';
  if(winner)     narrative += 'Predicted winner: <strong>'+esc(winner.name||'')+' ('+esc(winner.comment||'')+')</strong>. ';
  if(uOver)      narrative += 'Goals market: <strong>'+esc(uOver)+'</strong>. ';
  if(predGoals)  narrative += 'Predicted score — Home: <strong>'+predGoals.home+'</strong> | Away: <strong>'+predGoals.away+'</strong>. ';
  narrative += 'Poisson model (λ='+own.lam+') gives <strong>'+pct+'%</strong> probability for 2+ goals. ';
  narrative += 'Win split — Home: <strong>'+hW.toFixed(0)+'%</strong> · Draw: <strong>'+drw.toFixed(0)+'%</strong> · Away: <strong>'+aW.toFixed(0)+'%</strong>.';

  var formHtml=own.fc.length
    ? '<div class="form-row"><span class="form-lbl">Form</span>'+own.fc.map(function(c){return '<div class="fl '+c+'">'+c+'</div>';}).join('')+'</div>' : '';
  var tagsHtml=tags.map(function(t){return '<span class="tag '+t.c+'">'+t.l+'</span>';}).join('');

  var compHtml='';
  if (apiC) {
    var ks=[{k:'attacks',l:'Attack'},{k:'defence',l:'Defence'},{k:'poisson_distribution',l:'Poisson'},{k:'h2h',l:'H2H'},{k:'form',l:'Form'},{k:'goals_h2h',l:'Goals H2H'}];
    var rows=ks.map(function(ck){
      var c=apiC[ck.k]; if(!c) return '';
      var hv=parseFloat(String(c.home||'').replace('%',''))||50;
      var av=parseFloat(String(c.away||'').replace('%',''))||50;
      var tot=hv+av||100;
      var hp=(hv/tot*100).toFixed(0), ap=(av/tot*100).toFixed(0);
      return '<div class="comp-row">'
        +'<span class="comp-side-lbl" title="'+esc(fx.teams.home.name)+'">'+esc(fx.teams.home.name.split(' ')[0])+'</span>'
        +'<span class="comp-metric-lbl">'+ck.l+'</span>'
        +'<div class="comp-bar-track"><div class="comp-bar-home" style="width:'+hp+'%"></div><div class="comp-bar-away" style="width:'+ap+'%"></div></div>'
        +'<span class="comp-side-lbl right" title="'+esc(fx.teams.away.name)+'">'+esc(fx.teams.away.name.split(' ')[0])+'</span>'
        +'</div>';
    }).join('');
    if(rows.trim()) {
      compHtml='<div class="comp-section">'
        +'<div class="comp-title">Team Comparison — '+esc(fx.teams.home.name)+' vs '+esc(fx.teams.away.name)+'</div>'
        +rows+'</div>';
    }
  }

  return '<div class="fx-card" style="animation-delay:'+(idx*.1)+'s">'
    // head
    +'<div class="fx-head">'
    +(fx.league.logo?'<img src="'+fx.league.logo+'" style="width:18px;height:18px;object-fit:contain;flex-shrink:0" onerror="this.remove()">':'')
    +'<span class="fx-league-name">'+esc(fx.league.name)+'</span>'
    +'<span class="fx-country">'+esc(fx.league.country)+'</span>'
    +'<span class="fx-date">'+dstr+'</span>'
    +'</div>'
    // matchup
    +'<div class="matchup">'
    +tblk(fx.teams.home, fx.teams.home.id===team.id, '')
    +'<div class="m-center"><span class="m-vs">VS</span><span class="m-time">'+tstr+'</span></div>'
    +tblk(fx.teams.away, fx.teams.away.id===team.id, 'away')
    +'</div>'
    // win probability
    +'<div class="win-prob-section">'
    +'<div class="win-prob-label">Match Result Probability</div>'
    +'<div class="win-bar">'
    +'<div class="win-seg home" style="width:'+hW.toFixed(0)+'%">'+hW.toFixed(0)+'%</div>'
    +'<div class="win-seg draw" style="width:'+drw.toFixed(0)+'%">'+drw.toFixed(0)+'%</div>'
    +'<div class="win-seg away" style="width:'+aW.toFixed(0)+'%">'+aW.toFixed(0)+'%</div>'
    +'</div>'
    +'<div class="win-sub">'
    +'<span style="color:var(--blue);font-weight:600">'+esc(fx.teams.home.name)+' Win</span>'
    +'<span style="color:#92650a;font-weight:500">Draw</span>'
    +'<span style="color:var(--red);font-weight:600">'+esc(fx.teams.away.name)+' Win</span>'
    +'</div></div>'
    // markets
    +'<div class="markets-section">'
    +'<div class="markets-grid">'
    +mk('Match Winner', winner?(winner.name||'—'):'Our Model', winner&&winner.name===fx.teams.home.name?'var(--blue)':winner&&winner.name===fx.teams.away.name?'var(--red)':'var(--ink)', winner?winner.comment:'Statistical model', 'mkt-blue', pct, 'var(--blue)', confLbl, confCls)
    +mk('Draw Probability', drw.toFixed(0)+'%', '#92650a', drw>28?'Higher draw risk':'Below avg draw rate', 'mkt-amber', drw, 'var(--amber)', confLbl, confCls)
    +mk('2+ Goals', pct+'%', own.prob>=.65?'var(--green)':own.prob>=.45?'#92650a':'var(--red)', 'Poisson model λ='+own.lam, 'mkt-green', parseFloat(pct), 'var(--green)', confLbl, confCls)
    +mk('Over 2.5', o25v+'%', parseInt(o25v)>=55?'var(--green)':parseInt(o25v)>=40?'#92650a':'var(--red)', 'xG + historical avg', 'mkt-blue', parseInt(o25v), 'var(--blue)', confLbl, confCls)
    +mk('Over 1.5', o15+'%', parseInt(o15)>=65?'var(--green)':'#92650a', 'Higher probability market', 'mkt-teal', parseInt(o15), 'var(--teal)', confLbl, confCls)
    +mk('Over 3.5', o35+'%', parseInt(o35)>=40?'var(--green)':'var(--muted)', 'Lower probability threshold', 'mkt-purple', parseInt(o35), 'var(--purple)', confLbl, confCls)
    +mk('BTTS', bttsV+'%', own.btts>=.55?'var(--green)':own.btts>=.4?'#92650a':'var(--red)', 'Both teams to score', 'mkt-amber', own.btts*100, 'var(--amber)', confLbl, confCls)
    +mk('Clean Sheet', csV+'%', parseFloat(csV)>35?'var(--red)':'var(--green)', esc(team.name)+' keeps shutout', 'mkt-red', parseFloat(csV), 'var(--red)', confLbl, confCls)
    +mk('Double Chance', dc1+'%', 'var(--blue)', esc(fx.teams.home.name)+' Win or Draw', 'mkt-teal', parseInt(dc1), 'var(--teal)', confLbl, confCls)
    +mk('Predicted Score', predGoals?(predGoals.home+' – '+predGoals.away):'N/A', 'var(--purple)', '6-algorithm API model', 'mkt-purple', null, 'var(--purple)', pred?'HIGH':'LOW', pred?'conf-hi':'conf-lo')
    +'</div></div>'
    // comparison
    +compHtml
    // form
    +formHtml
    // tags
    +(tags.length?'<div class="tags-row">'+tagsHtml+'</div>':'')
    // analysis
    +'<div class="analysis"><div class="analysis-inner"><p>'+narrative+'</p></div></div>'
    +'</div>';
}

function renderGeneral(stats, team) {
  var own=model(stats,null,team);
  var pct=(own.prob*100).toFixed(1);
  var tags=[
    own.prob>=.65?{l:'Strong 2+ Signal',c:'hot'}:own.prob>=.45?{l:'Possible 2+',c:'warm'}:{l:'Unlikely 2+',c:'cold'},
    own.btts>=.55?{l:'BTTS Likely',c:'hot'}:{l:'Low BTTS',c:'cold'},
    own.o25>=.6?{l:'High-Scoring',c:'hot'}:{l:'Low-Scoring',c:'cold'},
  ].map(function(t){return '<span class="tag '+t.c+'">'+t.l+'</span>';}).join('');
  return '<div class="fx-card">'
    +'<div class="fx-head"><span class="fx-league-name">General Season Analysis</span><span class="fx-country">No upcoming fixtures found</span></div>'
    +'<div class="markets-section"><div class="markets-grid">'
    +mk('2+ Goals',pct+'%',own.prob>=.65?'var(--green)':own.prob>=.45?'#92650a':'var(--red)','Poisson λ='+own.lam,'mkt-green',parseFloat(pct),'var(--green)','MED','conf-md')
    +mk('Over 2.5',(own.o25*100).toFixed(0)+'%',own.o25>=.55?'var(--green)':'#92650a','Season avg based','mkt-blue',own.o25*100,'var(--blue)','MED','conf-md')
    +mk('BTTS',(own.btts*100).toFixed(0)+'%',own.btts>=.55?'var(--green)':'#92650a','Both teams score rate','mkt-amber',own.btts*100,'var(--amber)','MED','conf-md')
    +mk('xG (adj)',own.xg,'var(--blue)','Expected goals adjusted','mkt-teal',null,'var(--teal)','MED','conf-md')
    +'</div></div>'
    +(own.fc.length?'<div class="form-row"><span class="form-lbl">Form</span>'+own.fc.map(function(c){return '<div class="fl '+c+'">'+c+'</div>';}).join('')+'</div>':'')
    +'<div class="tags-row">'+tags+'</div>'
    +'<div class="analysis"><div class="analysis-inner"><p>No upcoming fixtures found. Analysis based on season statistics. Poisson λ=<strong>'+own.lam+'</strong> · 2+ Goals probability: <strong>'+pct+'%</strong>.</p></div></div>'
    +'</div>';
}

function renderH2H(fx, h2hData) {
  var hId=fx.teams.home.id, hW=0,aW=0,dr=0;
  h2hData.forEach(function(m){
    var hg=m.goals.home, ag=m.goals.away;
    if(hg===null||ag===null) return;
    if(hg>ag){if(m.teams.home.id===hId)hW++;else aW++;}
    else if(ag>hg){if(m.teams.away.id===hId)aW++;else hW++;}
    else dr++;
  });
  var tot=hW+aW+dr||1, hp=(hW/tot*100).toFixed(0), ap=(aW/tot*100).toFixed(0), dp=(dr/tot*100).toFixed(0);
  return sh('Head-to-Head · Last '+h2hData.length+' Meetings')
    +'<div class="standings-wrap" style="padding:18px 20px">'
    +'<div class="h2h-bar">'
    +'<div class="h2h-seg" style="width:'+hp+'%;background:var(--blue);border-radius:5px 0 0 5px"></div>'
    +'<div class="h2h-seg" style="width:'+dp+'%;background:var(--amber)"></div>'
    +'<div class="h2h-seg" style="width:'+ap+'%;background:var(--red);border-radius:0 5px 5px 0"></div>'
    +'</div>'
    +'<div class="h2h-legend">'
    +'<span style="color:var(--blue);font-weight:600">'+esc(fx.teams.home.name)+': '+hW+' wins</span>'
    +'<span style="color:#92650a;font-weight:500">Draws: '+dr+'</span>'
    +'<span style="color:var(--red);font-weight:600">'+esc(fx.teams.away.name)+': '+aW+' wins</span>'
    +'</div></div>';
}

function renderInjuries(injuries, fx, team) {
  var mine=injuries.filter(function(i){return i.team&&i.team.id===team.id;});
  var opp =injuries.filter(function(i){return i.team&&i.team.id!==team.id;});
  if(!mine.length&&!opp.length) return '';
  var html=sh('Injury Report'+(fx?' · '+fx.fixture.date?.slice(0,10):''))
    +'<div class="inj-section">';
  function row(inj){
    var p=inj.player||{}, t=inj.team||{};
    return '<div class="inj-item">'
      +(p.photo?'<img src="'+p.photo+'" style="width:28px;height:28px;border-radius:50%;object-fit:cover;flex-shrink:0" onerror="this.remove()">':'')
      +'<span class="inj-name">'+esc(p.name||'Unknown')+'</span>'
      +'<span class="inj-pos">'+esc(p.position||'')+'</span>'
      +'<span class="inj-type">'+esc(inj.reason||inj.type||'Injured')+'</span>'
      +'<span class="inj-team">'+esc(t.name||'')+'</span>'
      +'</div>';
  }
  mine.forEach(function(i){html+=row(i);});
  opp.forEach(function(i){html+=row(i);});
  html+='</div>';
  return html;
}

function renderStandings(standings, team) {
  if(!standings.length) return '';
  var top=standings.slice(0,Math.min(10,standings.length));
  if(!top.some(function(s){return s.team&&s.team.id===team.id;})){
    var tr=standings.find(function(s){return s.team&&s.team.id===team.id;});
    if(tr) top.push(tr);
  }
  var html=sh('League Table')
    +'<div class="standings-wrap"><table>'
    +'<thead><tr><th>#</th><th>Club</th><th>P</th><th>W</th><th>D</th><th>L</th><th>GF</th><th>GA</th><th>GD</th><th>Pts</th></tr></thead><tbody>';
  top.forEach(function(s){
    var mine=s.team&&s.team.id===team.id;
    html+='<tr class="'+(mine?'hl-row':'')+'">'
      +'<td style="color:var(--muted);font-family:\'DM Mono\',monospace;font-size:12px">'+s.rank+'</td>'
      +'<td><div style="display:flex;align-items:center;gap:8px">'
      +(s.team?.logo?'<img src="'+s.team.logo+'" style="width:20px;height:20px;object-fit:contain;flex-shrink:0" onerror="this.remove()">':'')
      +'<span style="font-weight:'+(mine?700:500)+';color:var(--'+(mine?'blue':'ink')+')">'+esc(s.team?.name||'')+'</span></div></td>'
      +'<td>'+s.all?.played+'</td>'
      +'<td style="color:var(--green);font-weight:600">'+s.all?.win+'</td>'
      +'<td style="color:#92650a;font-weight:500">'+s.all?.draw+'</td>'
      +'<td style="color:var(--red);font-weight:500">'+s.all?.lose+'</td>'
      +'<td>'+s.all?.goals?.for+'</td>'
      +'<td>'+s.all?.goals?.against+'</td>'
      +'<td style="color:var(--muted)">'+(s.goalsDiff>=0?'+':'')+s.goalsDiff+'</td>'
      +'<td><span class="pts-val">'+s.points+'</span></td>'
      +'</tr>';
  });
  html+='</tbody></table></div>';
  return html;
}

// ── HELPERS ───────────────────────────────────────────────────
function mk(lbl, val, col, sub, accentCls, barPct, barCol, confLbl, confCls) {
  var bar = barPct !== null
    ? '<div class="mkt-bar"><div class="mkt-bar-fill" style="width:'+Math.min(100,Math.max(0,barPct))+'%;background:'+barCol+'"></div></div>'
    : '';
  return '<div class="mkt-card '+accentCls+'">'
    +'<div class="mkt-card-top"><div class="mkt-card-lbl">'+lbl+'</div><span class="conf-badge '+confCls+'">'+confLbl+'</span></div>'
    +'<div class="mkt-val" style="color:'+col+'">'+val+'</div>'
    +'<div class="mkt-sub">'+sub+'</div>'
    +bar
    +'</div>';
}
function sv(l,v,col){ return '<div class="stat-cell"><div class="stat-val" style="color:'+col+'">'+v+'</div><div class="stat-lbl">'+l+'</div></div>'; }
function sh(label) {
  return '<div class="sec-head"><div class="sec-head-line"></div>'
    +'<span class="sec-head-label"><span class="sec-head-accent">◆</span> '+label+'</span>'
    +'<div class="sec-head-line"></div></div>';
}
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function showErr(msg){ var b=document.getElementById('errbar'); b.textContent='⚠ '+msg; b.style.display='block'; }
function hideErr(){ document.getElementById('errbar').style.display='none'; }
function clearReport(){ document.getElementById('report').style.display='none'; document.getElementById('report').innerHTML=''; input.value=''; input.focus(); }
</script>
</body>
