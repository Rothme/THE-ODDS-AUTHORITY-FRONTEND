<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Odds Authority — Match Prediction Centre</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ── DESIGN TOKENS ─────────────────────────────────────────── */
:root {
  --white:   #ffffff;
  --off:     #f7f8fc;
  --light:   #eef1f8;
  --rule:    #e2e6f0;
  --muted:   #8b95a8;
  --mid:     #4a5568;
  --dark:    #1a2236;
  --ink:     #0d1421;

  --blue:    #1d6aff;
  --blue-l:  #e8f0ff;
  --blue-d:  #1453d4;
  --blue-mid:#2f7bff;

  --green:   #0fba74;
  --green-l: #e6f9f1;
  --amber:   #f59e0b;
  --amber-l: #fef3cd;
  --red:     #ef4444;
  --red-l:   #fee2e2;
  --purple:  #7c3aed;
  --purple-l:#ede9fe;
  --teal:    #0ea5e9;
  --teal-l:  #e0f2fe;

  --radius:  6px;
  --shadow:  0 1px 4px rgba(13,20,33,.06), 0 4px 16px rgba(13,20,33,.08);
  --shadow-lg: 0 4px 24px rgba(13,20,33,.12), 0 12px 48px rgba(13,20,33,.1);
}

/* ── RESET ─────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
body {
  background: var(--off);
  color: var(--ink);
  font-family: 'DM Sans', system-ui, sans-serif;
  font-size: 15px;
  line-height: 1.6;
  min-height: 100vh;
}
img { display: block; max-width: 100%; }
button { font-family: inherit; cursor: pointer; }
input { font-family: inherit; }

.wrap { max-width: 1080px; margin: 0 auto; padding: 0 24px; }

/* ── HEADER ────────────────────────────────────────────────── */
header {
  background: var(--white);
  border-bottom: 1px solid var(--rule);
  position: sticky; top: 0; z-index: 200;
  box-shadow: 0 1px 0 var(--rule), 0 2px 12px rgba(13,20,33,.04);
}
.nav {
  display: flex; align-items: center; gap: 16px;
  padding: 16px 0;
}
.logo-mark {
  width: 36px; height: 36px; border-radius: 8px;
  background: var(--blue); display: flex; align-items: center;
  justify-content: center; flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(29,106,255,.35);
}
.logo-mark svg { width: 20px; height: 20px; }
.brand-text {}
.brand-name {
  font-family: 'Playfair Display', Georgia, serif;
  font-weight: 800; font-size: 18px;
  color: var(--ink); letter-spacing: -.3px; line-height: 1;
}
.brand-tag {
  font-family: 'DM Mono', monospace;
  font-size: 10px; color: var(--muted);
  letter-spacing: 1.5px; text-transform: uppercase; margin-top: 2px;
}
.nav-right { margin-left: auto; display: flex; gap: 10px; align-items: center; }
.status-chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 5px 12px; border-radius: 20px;
  font-family: 'DM Mono', monospace; font-size: 11px;
  font-weight: 500; letter-spacing: .5px;
  border: 1px solid var(--rule);
  color: var(--muted); background: var(--white);
  transition: all .3s;
}
.status-chip.connected {
  background: var(--green-l); border-color: rgba(15,186,116,.3);
  color: var(--green);
}
.status-chip.error { background: var(--red-l); border-color: rgba(239,68,68,.3); color: var(--red); }
.status-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: currentColor; animation: pulse-dot 2s ease infinite;
}
@keyframes pulse-dot {
  0%,100% { opacity: 1; transform: scale(1); }
  50% { opacity: .5; transform: scale(.7); }
}

/* ── HERO ──────────────────────────────────────────────────── */
.hero {
  background: var(--white);
  border-bottom: 1px solid var(--rule);
  padding: 56px 0 48px;
  text-align: center;
}
.hero-kicker {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--blue-l); color: var(--blue);
  font-family: 'DM Mono', monospace; font-size: 11px;
  font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase;
  padding: 5px 14px; border-radius: 20px;
  border: 1px solid rgba(29,106,255,.2);
  margin-bottom: 20px;
}
.hero-kicker-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--blue); }
.hero-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 900; line-height: 1.05;
  color: var(--ink); margin-bottom: 14px;
  letter-spacing: -1px;
}
.hero-title em { color: var(--blue); font-style: normal; }
.hero-desc {
  font-size: 16px; color: var(--mid);
  max-width: 480px; margin: 0 auto 32px;
  font-weight: 400; line-height: 1.65;
}

/* Markets tag row */
.mkt-tags {
  display: flex; gap: 8px; justify-content: center;
  flex-wrap: wrap; margin-bottom: 36px;
}
.mkt-tag {
  padding: 5px 14px; border-radius: 20px;
  font-size: 12px; font-weight: 500;
  border: 1px solid var(--rule);
  color: var(--mid); background: var(--off);
  white-space: nowrap;
}
.mkt-tag.blu { background: var(--blue-l); color: var(--blue); border-color: rgba(29,106,255,.2); }
.mkt-tag.grn { background: var(--green-l); color: var(--green); border-color: rgba(15,186,116,.25); }
.mkt-tag.amb { background: var(--amber-l); color: #92650a; border-color: rgba(245,158,11,.25); }
.mkt-tag.pur { background: var(--purple-l); color: var(--purple); border-color: rgba(124,58,237,.25); }
.mkt-tag.tel { background: var(--teal-l); color: var(--teal); border-color: rgba(14,165,233,.25); }

/* ── SEARCH ────────────────────────────────────────────────── */
.search-wrap { max-width: 560px; margin: 0 auto; position: relative; }
.search-label {
  display: block; font-family: 'DM Mono', monospace;
  font-size: 11px; font-weight: 500; color: var(--muted);
  letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px;
  text-align: left;
}
.search-field {
  position: relative;
  box-shadow: var(--shadow-lg);
  border-radius: var(--radius);
}
.search-input {
  width: 100%;
  background: var(--white);
  border: 1.5px solid var(--rule);
  border-radius: var(--radius);
  color: var(--ink); font-size: 16px; font-weight: 500;
  padding: 16px 52px 16px 20px;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
}
.search-input:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 4px rgba(29,106,255,.1);
}
.search-input::placeholder { color: var(--muted); font-weight: 400; }
.search-icon {
  position: absolute; right: 18px; top: 50%;
  transform: translateY(-50%);
  color: var(--muted); pointer-events: none; font-size: 18px;
}
.search-spinner {
  position: absolute; right: 18px; top: 50%;
  transform: translateY(-50%);
  width: 18px; height: 18px;
  border: 2px solid var(--rule);
  border-top-color: var(--blue);
  border-radius: 50%;
  animation: spin .65s linear infinite; display: none;
}
@keyframes spin { to { transform: translateY(-50%) rotate(360deg); } }

/* Dropdown */
.dropdown {
  position: absolute; top: calc(100% + 6px); left: 0; right: 0;
  background: var(--white); border: 1px solid var(--rule);
  border-radius: var(--radius); z-index: 500;
  box-shadow: var(--shadow-lg); display: none;
  max-height: 320px; overflow-y: auto;
}
.dd-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 16px; cursor: pointer;
  border-bottom: 1px solid var(--rule);
  transition: background .12s;
}
.dd-item:last-child { border-bottom: none; }
.dd-item:hover, .dd-item.active { background: var(--blue-l); }
.dd-logo {
  width: 36px; height: 36px; border-radius: 50%;
  object-fit: contain; background: var(--off);
  border: 1px solid var(--rule); padding: 3px; flex-shrink: 0;
}
.dd-ph {
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--light); border: 1px solid var(--rule);
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; flex-shrink: 0;
}
.dd-name { font-weight: 600; font-size: 14px; color: var(--ink); }
.dd-meta { font-size: 12px; color: var(--muted); margin-top: 1px; }
.dd-country {
  margin-left: auto; font-family: 'DM Mono', monospace;
  font-size: 10px; color: var(--blue);
  background: var(--blue-l); border: 1px solid rgba(29,106,255,.2);
  padding: 2px 8px; border-radius: 10px; white-space: nowrap; flex-shrink: 0;
}
.dd-empty { padding: 20px; text-align: center; color: var(--muted); font-size: 13px; }

/* ── MAIN CONTENT AREA ─────────────────────────────────────── */
.main { padding: 32px 0 80px; }

/* Error */
.err-bar {
  background: var(--red-l); border: 1px solid rgba(239,68,68,.3);
  border-radius: var(--radius); padding: 14px 18px;
  color: var(--red); font-size: 13px; font-weight: 500;
  margin-bottom: 20px; display: none;
}

/* Loading */
.loader {
  display: none; background: var(--white);
  border: 1px solid var(--rule); border-radius: var(--radius);
  padding: 48px 32px; text-align: center;
  box-shadow: var(--shadow);
}
.loader-ring {
  width: 48px; height: 48px; border-radius: 50%;
  border: 3px solid var(--light);
  border-top-color: var(--blue);
  animation: spin2 .8s linear infinite;
  margin: 0 auto 20px;
}
@keyframes spin2 { to { transform: rotate(360deg); } }
.loader-steps { max-width: 280px; margin: 0 auto; text-align: left; }
.lstep {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; color: var(--muted); padding: 5px 0;
  transition: color .3s;
}
.lstep.done { color: var(--green); font-weight: 500; }
.lstep-ico { width: 16px; flex-shrink: 0; text-align: center; font-size: 12px; }

/* ── REPORT ────────────────────────────────────────────────── */
#report { display: none; }

/* Team strip */
.team-strip {
  background: var(--white);
  border: 1px solid var(--rule);
  border-radius: var(--radius);
  padding: 24px 28px;
  display: flex; align-items: center; gap: 20px;
  margin-bottom: 20px;
  box-shadow: var(--shadow);
  position: relative; overflow: hidden;
}
.team-strip::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0;
  width: 4px; background: var(--blue);
}
.t-logo {
  width: 64px; height: 64px; object-fit: contain;
  border-radius: 50%; border: 2px solid var(--rule);
  background: var(--off); padding: 4px; flex-shrink: 0;
}
.t-ph {
  width: 64px; height: 64px; border-radius: 50%;
  background: var(--light); border: 2px solid var(--rule);
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; flex-shrink: 0;
}
.t-name {
  font-family: 'Playfair Display', serif;
  font-size: clamp(18px, 3vw, 26px); font-weight: 800;
  color: var(--ink); margin-bottom: 3px; letter-spacing: -.3px;
}
.t-meta { font-size: 13px; color: var(--muted); }
.t-league { font-size: 12px; color: var(--blue); font-weight: 500; margin-top: 3px; }
.back-btn {
  margin-left: auto; flex-shrink: 0;
  background: var(--off); border: 1px solid var(--rule);
  color: var(--mid); font-size: 13px; font-weight: 500;
  padding: 8px 16px; border-radius: var(--radius);
  transition: all .2s;
}
.back-btn:hover { background: var(--blue); border-color: var(--blue); color: var(--white); }

/* Section heading */
.sec-head {
  display: flex; align-items: center; gap: 12px;
  margin: 28px 0 14px;
}
.sec-head-line { flex: 1; height: 1px; background: var(--rule); }
.sec-head-label {
  font-family: 'DM Mono', monospace;
  font-size: 11px; font-weight: 500; color: var(--muted);
  letter-spacing: 1.5px; text-transform: uppercase; white-space: nowrap;
}
.sec-head-accent { color: var(--blue); }

/* Season stats grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
  gap: 10px; margin-bottom: 8px;
}
.stat-cell {
  background: var(--white); border: 1px solid var(--rule);
  border-radius: var(--radius); padding: 16px 12px;
  text-align: center; box-shadow: var(--shadow);
  transition: transform .15s, box-shadow .15s;
}
.stat-cell:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
.stat-val {
  font-family: 'Playfair Display', serif;
  font-size: 26px; font-weight: 800; line-height: 1; margin-bottom: 5px;
}
.stat-lbl {
  font-family: 'DM Mono', monospace; font-size: 9px;
  color: var(--muted); letter-spacing: 1px; text-transform: uppercase;
}

/* ── FIXTURE CARD ───────────────────────────────────────────── */
.fx-card {
  background: var(--white); border: 1px solid var(--rule);
  border-radius: var(--radius); margin-bottom: 20px;
  box-shadow: var(--shadow); overflow: hidden;
  animation: slideUp .35s ease both;
}
@keyframes slideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

/* Card header */
.fx-head {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 20px; border-bottom: 1px solid var(--rule);
  background: var(--off);
}
.fx-league-name { font-size: 12px; font-weight: 600; color: var(--blue); }
.fx-country { font-size: 12px; color: var(--muted); }
.fx-date {
  margin-left: auto; font-family: 'DM Mono', monospace;
  font-size: 11px; color: var(--muted);
}

/* Matchup */
.matchup {
  display: grid; grid-template-columns: 1fr auto 1fr;
  align-items: center; gap: 12px;
  padding: 24px 28px; border-bottom: 1px solid var(--rule);
}
.m-side { display: flex; align-items: center; gap: 12px; }
.m-side.away { flex-direction: row-reverse; text-align: right; }
.m-tlogo {
  width: 44px; height: 44px; object-fit: contain;
  border-radius: 50%; background: var(--off);
  border: 1.5px solid var(--rule); padding: 3px; flex-shrink: 0;
}
.m-tph {
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--light); border: 1.5px solid var(--rule);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex-shrink: 0;
}
.m-tname { font-size: 16px; font-weight: 700; color: var(--ink); line-height: 1.2; }
.m-tname.subject { color: var(--blue); }
.m-center { text-align: center; }
.m-vs {
  font-family: 'Playfair Display', serif;
  font-size: 13px; font-weight: 800; color: var(--muted); display: block;
}
.m-time {
  font-family: 'DM Mono', monospace;
  font-size: 11px; color: var(--muted); display: block; margin-top: 4px;
}

/* ── WIN PROBABILITY BAR ────────────────────────────────────── */
.win-prob-section { padding: 20px 28px; border-bottom: 1px solid var(--rule); }
.win-prob-label {
  font-family: 'DM Mono', monospace; font-size: 10px;
  color: var(--muted); letter-spacing: 1px; text-transform: uppercase;
  margin-bottom: 10px;
}
.win-bar {
  display: flex; height: 40px; border-radius: var(--radius);
  overflow: hidden; gap: 2px; margin-bottom: 10px;
}
.win-seg {
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700;
  transition: width .9s cubic-bezier(.16,1,.3,1); min-width: 0;
  overflow: hidden; white-space: nowrap;
}
.win-seg.home { background: #dbeafe; color: var(--blue); border-radius: var(--radius) 0 0 var(--radius); }
.win-seg.draw { background: #fef9c3; color: #854d0e; }
.win-seg.away { background: #fee2e2; color: var(--red); border-radius: 0 var(--radius) var(--radius) 0; }
.win-sub {
  display: flex; justify-content: space-between;
  font-size: 12px; font-weight: 500;
}

/* ── MARKETS GRID ───────────────────────────────────────────── */
.markets-section { padding: 20px 28px; border-bottom: 1px solid var(--rule); }
.markets-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 10px;
}
.mkt-card {
  background: var(--off); border: 1px solid var(--rule);
  border-radius: var(--radius); padding: 14px 14px 12px;
  position: relative; transition: transform .15s, box-shadow .15s;
}
.mkt-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); background: var(--white); }
.mkt-card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 8px; }
.mkt-card-lbl {
  font-family: 'DM Mono', monospace; font-size: 9px;
  color: var(--muted); letter-spacing: 1px; text-transform: uppercase;
  line-height: 1.3;
}
.conf-badge {
  font-family: 'DM Mono', monospace; font-size: 9px; font-weight: 500;
  padding: 2px 6px; border-radius: 4px; flex-shrink: 0;
}
.conf-hi { background: var(--green-l); color: var(--green); }
.conf-md { background: var(--amber-l); color: #92650a; }
.conf-lo { background: var(--light); color: var(--muted); }
.mkt-val {
  font-family: 'Playfair Display', serif;
  font-size: 22px; font-weight: 800; line-height: 1;
  margin-bottom: 3px;
}
.mkt-sub { font-size: 11px; color: var(--muted); }
.mkt-bar { height: 3px; background: var(--light); border-radius: 2px; overflow: hidden; margin-top: 8px; }
.mkt-bar-fill { height: 100%; border-radius: 2px; transition: width .9s ease; }

/* Accent left borders per market type */
.mkt-blue  { border-left: 3px solid var(--blue); }
.mkt-green { border-left: 3px solid var(--green); }
.mkt-amber { border-left: 3px solid var(--amber); }
.mkt-red   { border-left: 3px solid var(--red); }
.mkt-purple{ border-left: 3px solid var(--purple); }
.mkt-teal  { border-left: 3px solid var(--teal); }

/* ── COMPARISON SECTION ─────────────────────────────────────── */
.comp-section { padding: 20px 28px; border-bottom: 1px solid var(--rule); }
.comp-title {
  font-family: 'DM Mono', monospace; font-size: 10px;
  color: var(--muted); letter-spacing: 1px; text-transform: uppercase;
  margin-bottom: 14px;
}
.comp-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.comp-side-lbl { font-size: 11px; color: var(--muted); font-weight: 500; width: 80px; text-align: right; flex-shrink: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.comp-side-lbl.right { text-align: left; }
.comp-metric-lbl { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); width: 70px; text-align: center; flex-shrink: 0; }
.comp-bar-track { flex: 1; height: 8px; background: var(--light); border-radius: 4px; overflow: hidden; display: flex; }
.comp-bar-home { height: 100%; background: var(--blue); border-radius: 4px 0 0 4px; transition: width .8s ease; }
.comp-bar-away { height: 100%; background: var(--red); border-radius: 0 4px 4px 0; transition: width .8s ease; }

/* ── H2H ────────────────────────────────────────────────────── */
.h2h-section { padding: 20px 28px; border-bottom: 1px solid var(--rule); }
.h2h-bar { display: flex; height: 10px; border-radius: 5px; overflow: hidden; margin: 8px 0 10px; }
.h2h-seg { height: 100%; transition: width .8s ease; }
.h2h-legend { display: flex; justify-content: space-between; font-size: 12px; font-weight: 500; }

/* ── INJURIES ───────────────────────────────────────────────── */
.inj-section { padding: 16px 28px; border-bottom: 1px solid var(--rule); }
.inj-item {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 14px; background: var(--off);
  border: 1px solid var(--rule); border-radius: var(--radius);
  margin-bottom: 6px; font-size: 13px;
}
.inj-item:last-child { margin-bottom: 0; }
.inj-name { font-weight: 600; flex: 1; }
.inj-pos { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; }
.inj-type { font-size: 11px; color: var(--red); font-weight: 500; }
.inj-team { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; margin-left: auto; }

/* ── FORM LETTERS ───────────────────────────────────────────── */
.form-row { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; padding: 14px 28px; border-bottom: 1px solid var(--rule); }
.form-lbl { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; margin-right: 4px; }
.fl {
  width: 24px; height: 24px; border-radius: 5px;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700;
}
.fl.W { background: var(--green-l); color: var(--green); }
.fl.D { background: var(--amber-l); color: #92650a; }
.fl.L { background: var(--red-l); color: var(--red); }

/* ── TAGS ───────────────────────────────────────────────────── */
.tags-row { display: flex; gap: 6px; flex-wrap: wrap; padding: 14px 28px; border-bottom: 1px solid var(--rule); }
.tag {
  font-size: 11px; font-weight: 500;
  padding: 4px 10px; border-radius: 12px;
  border: 1px solid var(--rule);
}
.tag.hot { background: var(--green-l); color: var(--green); border-color: rgba(15,186,116,.25); }
.tag.warm { background: var(--amber-l); color: #92650a; border-color: rgba(245,158,11,.25); }
.tag.cold { background: var(--red-l); color: var(--red); border-color: rgba(239,68,68,.25); }
